# Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# AI Model Configuration
# =============================================================================

# HuggingFace API Token (Required for GPT-OSS model via HuggingFace)
# Get your token from: https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token_here

# Llama API URL (Optional - for local Llama 3.2 model)
# Default: http://localhost:11434/v1
# Only change if your Ollama server runs on a different host/port
# LLAMA_API_URL=http://localhost:11434/v1

# =============================================================================
# Flask Configuration
# =============================================================================

SECRET_KEY=your-secret-key-change-in-production
FLASK_ENV=development

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
