SECRET_KEY=your-secret-key-change-in-production
FLASK_ENV=production

# CORS Origins (comma-separated) - set to your Vercel frontend URL in production
CORS_ORIGINS=https://py-test-genie.vercel.app,http://localhost:3000,http://localhost:5173

# =============================================================================
# Database (MongoDB)
# =============================================================================

# Local development:
# MONGODB_URL=mongodb://localhost:27017

# Production (MongoDB Atlas):
MONGODB_URL=mongodb+srv://<username>:<password>@cluster.mongodb.net/?retryWrites=true&w=majority
DATABASE_NAME=pyTestGenie

# =============================================================================
# JWT Authentication
# =============================================================================

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# =============================================================================
# AI Models
# =============================================================================

# HuggingFace API Token (for GPT-OSS model)
HF_TOKEN=your_huggingface_token_here

# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# Ollama / Local Llama (only needed for local development with Ollama running)
# In production (Render), Ollama is NOT available — leave as default or omit
OLLAMA_BASE_URL=http://localhost:11434

# =============================================================================
# Live Deployment URLs
# =============================================================================

FRONTEND_URL=https://py-test-genie.vercel.app
BACKEND_URL=https://pytestgenie.onrender.com

# =============================================================================
# Email Configuration (for Password Reset)
# =============================================================================

SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password
SENDER_EMAIL=noreply@pytestgenie.com
SENDER_NAME=PyTestGenie

# Gmail setup:
# 1. Enable 2-Factor Authentication on your Google account
# 2. Go to https://myaccount.google.com/apppasswords
# 3. Generate an App Password and use it as SMTP_PASSWORD
