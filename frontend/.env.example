# Frontend Environment Variables
# Copy this file to .env and fill in your values
# Vite requires VITE_ prefix for all client-side env variables

# =====================================================
# Backend API URL
# =====================================================

# Production (Render backend URL):
VITE_API_BASE_URL=https://pytestgenie.onrender.com/api

# Local development:
# VITE_API_BASE_URL=http://localhost:5000/api

# =====================================================
# Live Deployment URLs (for reference)
# =====================================================
# Frontend: https://py-test-genie.vercel.app
# Backend:  https://pytestgenie.onrender.com
